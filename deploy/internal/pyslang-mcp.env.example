# Copy this file to deploy/internal/.env, or run:
# python3 scripts/setup_internal_maas.py --workspace /absolute/path/to/rtl

# Absolute path on the internal server that contains the RTL checkout.
# Inside the container this path is mounted read-only at /workspace.
PYSLANG_MCP_WORKSPACE=/absolute/path/to/rtl-checkout

# Host port. The compose file binds this only to 127.0.0.1 on the server.
PYSLANG_MCP_HTTP_PORT=8000

# Generate a long random value for real use.
# Example:
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
PYSLANG_MCP_HTTP_BEARER_TOKEN=replace-with-a-long-random-token
